# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# API-Football — https://www.api-football.com/ (Pro plan $19/mo recommended)
# World Cup: league=1, season=2026
API_FOOTBALL_KEY=your-api-football-key

# Friends-only signup code
INVITE_CODE=%%%

# Protects /api/cron/* — set the same value in Vercel env vars.
# Vercel Cron (vercel.json) sends Authorization: Bearer <this value> automatically.
# Use ONLY Vercel Cron on Pro — do not also schedule cron-job.org on the same URL.
CRON_SECRET=generate-a-long-random-string

# HMAC secret for unlisted /share/*?token=... links (falls back to CRON_SECRET).
# /share/picks?token=... — all matches; /share/match/[id]?token=... — single match.
SHARE_LINK_SECRET=generate-another-long-random-string

# Discord channel webhook — create in Discord: Channel → Integrations → Webhooks
# Never commit the real URL. Optional: skip locally if unset.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
